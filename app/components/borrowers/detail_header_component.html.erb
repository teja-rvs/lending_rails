<header class="rounded-3xl border border-slate-200 bg-white p-8 shadow-sm sm:p-10">
  <div class="flex flex-col gap-6 xl:flex-row xl:items-start xl:justify-between">
    <div class="max-w-3xl space-y-4">
      <p class="text-sm font-semibold uppercase tracking-[0.24em] text-slate-500">Borrower details</p>
      <div class="space-y-3">
        <h1 class="text-3xl font-semibold tracking-tight text-slate-950 sm:text-4xl"><%= borrower.full_name %></h1>
        <p class="text-sm leading-6 text-slate-600">
          <span class="font-semibold text-slate-900"><%= borrower.phone_number_normalized %></span>
          is the canonical borrower record. Use this page to confirm identity, current lending context, and the linked record trail before you move to the next protected workflow step.
        </p>
      </div>
    </div>

    <div class="flex flex-col gap-3 sm:flex-row sm:flex-wrap xl:max-w-md xl:justify-end">
      <%= link_to "Back to borrower list", borrowers_path, class: "inline-flex items-center justify-center rounded-xl border border-slate-300 px-5 py-3 text-sm font-semibold text-slate-700 transition hover:border-slate-400 hover:text-slate-950" %>
      <%= link_to "Return to workspace", root_path, class: "inline-flex items-center justify-center rounded-xl bg-slate-950 px-5 py-3 text-sm font-semibold text-white transition hover:bg-slate-800" %>
    </div>
  </div>

  <section class="mt-8 rounded-3xl border p-6 <%= eligibility_panel_classes %>">
    <div class="flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
      <div class="max-w-3xl space-y-2">
        <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-500">Application readiness</p>
        <h2 class="text-2xl font-semibold tracking-tight text-slate-950"><%= eligibility.headline %></h2>
        <p class="text-sm leading-6 text-slate-700"><%= eligibility.message %></p>
      </div>

      <span class="inline-flex items-center justify-center rounded-full border px-4 py-2 text-sm font-semibold <%= eligibility_badge_classes %>">
        <%= eligibility_badge_label %>
      </span>
    </div>
  </section>

  <div class="mt-6 grid gap-4 md:grid-cols-3">
    <article class="rounded-2xl border border-slate-200 bg-slate-50 p-5">
      <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-500">Current lending context</p>
      <p class="mt-3 text-lg font-semibold text-slate-950"><%= current_context.headline %></p>
      <p class="mt-2 text-sm leading-6 text-slate-600"><%= current_context.summary %></p>
    </article>

    <article class="rounded-2xl border border-slate-200 bg-slate-50 p-5">
      <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-500">Applications linked</p>
      <p class="mt-3 text-3xl font-semibold tracking-tight text-slate-950"><%= current_context.application_count %></p>
      <p class="mt-2 text-sm leading-6 text-slate-600">Visible application records tied to this borrower.</p>
    </article>

    <article class="rounded-2xl border border-slate-200 bg-slate-50 p-5">
      <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-500">Loans linked</p>
      <p class="mt-3 text-3xl font-semibold tracking-tight text-slate-950"><%= current_context.loan_count %></p>
      <p class="mt-2 text-sm leading-6 text-slate-600">Visible loan records tied to this borrower.</p>
    </article>
  </div>
</header>
