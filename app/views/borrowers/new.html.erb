<% content_for :title, "Create borrower | lending_rails" %>

<% full_name_error_id = "borrower_full_name_error" %>
<% phone_number_error_id = "borrower_phone_number_error" %>
<% phone_number_hint_id = "borrower_phone_number_hint" %>

<section class="mx-auto flex w-full max-w-5xl flex-1 flex-col gap-8">
  <div class="flex items-center gap-3 text-sm text-slate-600">
    <%= link_to "Workspace", root_path, class: "font-medium text-slate-700 underline decoration-slate-300 underline-offset-4 transition hover:text-slate-950 hover:decoration-slate-500" %>
    <span aria-hidden="true" class="text-slate-300">/</span>
    <span>Create borrower</span>
  </div>

  <div class="grid gap-6 lg:grid-cols-[minmax(0,2fr)_minmax(18rem,1fr)]">
    <section class="rounded-3xl border border-slate-200 bg-white p-8 shadow-sm sm:p-10">
      <p class="text-sm font-semibold uppercase tracking-[0.24em] text-slate-500">Borrower intake</p>
      <h1 class="mt-4 text-3xl font-semibold tracking-tight text-slate-950">Create borrower</h1>
      <p class="mt-3 max-w-2xl text-sm leading-6 text-slate-600">
        Add a borrower with the minimum identity details needed to start the lending workflow. The information stays server-validated, so
        duplicate or invalid phone numbers can be corrected here without losing your place.
      </p>

      <% if @borrower.errors.any? %>
        <div class="mt-8 rounded-2xl border border-rose-200 bg-rose-50 px-5 py-4" role="alert" aria-live="assertive" tabindex="-1">
          <h2 class="text-sm font-semibold text-rose-900">Please correct the highlighted fields.</h2>
          <ul class="mt-3 space-y-2 text-sm text-rose-700">
            <% @borrower.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <%= form_with model: @borrower, class: "mt-8 space-y-8" do |form| %>
        <div class="grid gap-6 lg:grid-cols-2">
          <div class="space-y-2">
            <%= form.label :full_name, "Full name", class: "block text-sm font-medium text-slate-700" %>
            <%= form.text_field :full_name,
                required: true,
                autofocus: true,
                autocomplete: "name",
                placeholder: "Asha Patel",
                aria: {
                  invalid: @borrower.errors[:full_name].any?,
                  describedby: (@borrower.errors[:full_name].any? ? full_name_error_id : nil)
                },
                class: class_names(
                  "block w-full rounded-xl border bg-white px-4 py-3 text-sm text-slate-900 shadow-sm transition focus:outline-none focus:ring-2",
                  @borrower.errors[:full_name].any? ? "border-rose-300 focus:border-rose-400 focus:ring-rose-200" : "border-slate-300 focus:border-slate-400 focus:ring-slate-950/10"
                ) %>
            <% @borrower.errors.full_messages_for(:full_name).each do |message| %>
              <p id="<%= full_name_error_id %>" class="text-sm font-medium text-rose-700"><%= message %></p>
            <% end %>
          </div>

          <div class="space-y-2">
            <%= form.label :phone_number, "Phone number", class: "block text-sm font-medium text-slate-700" %>
            <%= form.telephone_field :phone_number,
                required: true,
                autocomplete: "tel",
                placeholder: "+91 98765 43210",
                aria: {
                  invalid: @borrower.errors[:phone_number].any?,
                  describedby: class_names(
                    phone_number_hint_id,
                    @borrower.errors[:phone_number].any? ? phone_number_error_id : nil
                  )
                },
                class: class_names(
                  "block w-full rounded-xl border bg-white px-4 py-3 text-sm text-slate-900 shadow-sm transition focus:outline-none focus:ring-2",
                  @borrower.errors[:phone_number].any? ? "border-rose-300 focus:border-rose-400 focus:ring-rose-200" : "border-slate-300 focus:border-slate-400 focus:ring-slate-950/10"
                ) %>
            <p id="<%= phone_number_hint_id %>" class="text-xs leading-5 text-slate-500">Enter the borrower&apos;s phone number in a valid format so it can be matched reliably later.</p>
            <% @borrower.errors.full_messages_for(:phone_number).each do |message| %>
              <p id="<%= phone_number_error_id %>" class="text-sm font-medium text-rose-700"><%= message %></p>
            <% end %>
          </div>
        </div>

        <div class="flex flex-col gap-3 border-t border-slate-200 pt-6 sm:flex-row sm:items-center sm:justify-between">
          <p class="text-sm leading-6 text-slate-500">
            This flow creates the borrower record only. Lending history, applications, and eligibility checks come in later stories.
          </p>
          <div class="flex flex-col gap-3 sm:flex-row">
            <%= link_to "Back to workspace", root_path, class: "inline-flex items-center justify-center rounded-xl border border-slate-300 px-5 py-3 text-sm font-semibold text-slate-700 transition hover:border-slate-400 hover:text-slate-950" %>
            <%= form.submit "Create borrower", class: "inline-flex items-center justify-center rounded-xl bg-slate-950 px-5 py-3 text-sm font-semibold text-white transition hover:bg-slate-800 focus:outline-none focus:ring-2 focus:ring-slate-950/15 focus:ring-offset-2 cursor-pointer" %>
          </div>
        </div>
      <% end %>
    </section>

    <aside class="rounded-3xl border border-slate-200 bg-slate-950 p-8 text-slate-100 shadow-sm">
      <h2 class="text-xl font-semibold">What happens next</h2>
      <ul class="mt-5 space-y-3 text-sm leading-6 text-slate-300">
        <li>The borrower is saved with canonical phone normalization from the existing borrower foundation.</li>
        <li>Duplicate or invalid phone numbers stay on this screen so you can correct the entry immediately.</li>
        <li>After a successful save, you land on a thin confirmation page with the borrower identity you just created.</li>
      </ul>
    </aside>
  </div>
</section>
