<% content_for :title, "Borrower details | lending_rails" %>

<section class="mx-auto flex w-full max-w-6xl flex-1 flex-col gap-8">
  <nav aria-label="Breadcrumb" class="flex flex-wrap items-center gap-3 text-sm text-slate-600">
    <%= link_to "Workspace", root_path, class: "font-medium text-slate-700 underline decoration-slate-300 underline-offset-4 transition hover:text-slate-950 hover:decoration-slate-500" %>
    <span aria-hidden="true" class="text-slate-300">/</span>
    <%= link_to "Borrowers", borrowers_path, class: "font-medium text-slate-700 underline decoration-slate-300 underline-offset-4 transition hover:text-slate-950 hover:decoration-slate-500" %>
    <span aria-hidden="true" class="text-slate-300">/</span>
    <span class="font-medium text-slate-950"><%= @borrower.full_name %></span>
  </nav>

  <%= render Borrowers::DetailHeaderComponent.new(
    borrower: @borrower_detail.borrower,
    current_context: @borrower_detail.current_context
  ) %>

  <div class="grid gap-6 xl:grid-cols-[minmax(0,2fr)_minmax(22rem,1fr)]">
    <%= render Borrowers::LinkedRecordsPanelComponent.new(
      linked_records: @borrower_detail.linked_records,
      history_state: @borrower_detail.history_state,
      next_step_message: @borrower_detail.next_step_message
    ) %>

    <aside class="space-y-6">
      <section class="rounded-3xl border border-slate-200 bg-white p-8 shadow-sm">
        <h2 class="text-xl font-semibold text-slate-950">Borrower identity</h2>
        <dl class="mt-6 space-y-5">
          <div>
            <dt class="text-sm font-medium text-slate-500">Full name</dt>
            <dd class="mt-2 text-lg font-semibold text-slate-950"><%= @borrower.full_name %></dd>
          </div>

          <div>
            <dt class="text-sm font-medium text-slate-500">Phone number</dt>
            <dd class="mt-2 text-lg font-semibold text-slate-950"><%= @borrower.phone_number_normalized %></dd>
          </div>
        </dl>
      </section>

      <section class="rounded-3xl border border-slate-200 bg-slate-950 p-8 text-slate-100 shadow-sm">
        <h2 class="text-xl font-semibold">Next-step orientation</h2>
        <p class="mt-4 text-sm leading-6 text-slate-300"><%= @borrower_detail.next_step_message %></p>
        <p class="mt-4 text-sm leading-6 text-slate-300">
          This page stays read-only in this story. Use it to confirm borrower context, then continue working inside the protected workspace.
        </p>
      </section>
    </aside>
  </div>
</section>
