<% content_for :title, "Borrower record | lending_rails" %>

<section class="mx-auto flex w-full max-w-5xl flex-1 flex-col gap-8">
  <div class="flex items-center gap-3 text-sm text-slate-600">
    <%= link_to "Workspace", root_path, class: "font-medium text-slate-700 underline decoration-slate-300 underline-offset-4 transition hover:text-slate-950 hover:decoration-slate-500" %>
    <span aria-hidden="true" class="text-slate-300">/</span>
    <%= link_to "Borrowers", borrowers_path, class: "font-medium text-slate-700 underline decoration-slate-300 underline-offset-4 transition hover:text-slate-950 hover:decoration-slate-500" %>
    <span aria-hidden="true" class="text-slate-300">/</span>
    <span>Borrower record</span>
  </div>

  <div class="grid gap-6 lg:grid-cols-[minmax(0,2fr)_minmax(18rem,1fr)]">
    <section class="rounded-3xl border border-emerald-200 bg-white p-8 shadow-sm sm:p-10">
      <p class="text-sm font-semibold uppercase tracking-[0.24em] text-emerald-700">Borrower saved</p>
      <h1 class="mt-4 text-3xl font-semibold tracking-tight text-slate-950">Borrower record</h1>
      <p class="mt-3 max-w-2xl text-sm leading-6 text-slate-600">
        The borrower record is now available for lookup and the next lending steps. This page stays intentionally light until later stories add
        fuller borrower history and linked workflow actions.
      </p>

      <dl class="mt-8 grid gap-5 rounded-2xl border border-slate-200 bg-slate-50 p-6 sm:grid-cols-2">
        <div>
          <dt class="text-sm font-medium text-slate-500">Full name</dt>
          <dd class="mt-2 text-lg font-semibold text-slate-950"><%= @borrower.full_name %></dd>
        </div>

        <div>
          <dt class="text-sm font-medium text-slate-500">Phone number</dt>
          <dd class="mt-2 text-lg font-semibold text-slate-950"><%= @borrower.phone_number_normalized %></dd>
        </div>
      </dl>

      <div class="mt-8 flex flex-col gap-3 sm:flex-row">
        <%= link_to "Back to borrower list", borrowers_path, class: "inline-flex items-center justify-center rounded-xl border border-slate-300 px-5 py-3 text-sm font-semibold text-slate-700 transition hover:border-slate-400 hover:text-slate-950" %>
        <%= link_to "Create another borrower", new_borrower_path, class: "inline-flex items-center justify-center rounded-xl bg-slate-950 px-5 py-3 text-sm font-semibold text-white transition hover:bg-slate-800" %>
        <%= link_to "Return to workspace", root_path, class: "inline-flex items-center justify-center rounded-xl border border-slate-300 px-5 py-3 text-sm font-semibold text-slate-700 transition hover:border-slate-400 hover:text-slate-950" %>
      </div>
    </section>

    <aside class="rounded-3xl border border-slate-200 bg-slate-950 p-8 text-slate-100 shadow-sm">
      <h2 class="text-xl font-semibold">Next-step orientation</h2>
      <p class="mt-4 text-sm leading-6 text-slate-300">
        This surface stays intentionally thin. Use the borrower list to find records operationally, while richer borrower history and eligibility
        checks arrive in later workflow slices.
      </p>
    </aside>
  </div>
</section>
