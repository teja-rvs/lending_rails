<% content_for :title, "#{@loan_application.application_number} | lending_rails" %>

<% editable = @loan_application.editable_pre_decision_details? %>
<% active_review_step = @loan_application.active_review_step %>
<% workflow_complete = active_review_step.nil? && @loan_application.review_steps.any? %>
<% waiting_for_details = active_review_step&.status == "waiting for details" %>
<% final_decision = LoanApplication::FINAL_DECISION_STATUSES.include?(@loan_application.status) %>
<% approvable = workflow_complete && @loan_application.approvable? %>
<% linked_loan = @loan_application.loan %>
<% borrower_context = @borrower_history.current_context %>
<% borrower_eligibility = @borrower_history.eligibility %>
<% detail_source = params[:from].presence %>
<% detail_from_applications = detail_source == "applications" %>

<section class="mx-auto flex w-full max-w-5xl flex-1 flex-col gap-8">
  <nav aria-label="Breadcrumb" class="flex flex-wrap items-center gap-3 text-sm text-slate-600">
    <%= link_to "Workspace", root_path, class: "font-medium text-slate-700 underline decoration-slate-300 underline-offset-4 transition hover:text-slate-950 hover:decoration-slate-500" %>
    <span aria-hidden="true" class="text-slate-300">/</span>
    <% if detail_from_applications %>
      <%= link_to "Applications", loan_applications_path, class: "font-medium text-slate-700 underline decoration-slate-300 underline-offset-4 transition hover:text-slate-950 hover:decoration-slate-500" %>
      <span aria-hidden="true" class="text-slate-300">/</span>
    <% end %>
    <%= link_to "Borrowers", borrowers_path, class: "font-medium text-slate-700 underline decoration-slate-300 underline-offset-4 transition hover:text-slate-950 hover:decoration-slate-500" %>
    <span aria-hidden="true" class="text-slate-300">/</span>
    <%= link_to @loan_application.borrower.full_name, borrower_path(@loan_application.borrower), class: "font-medium text-slate-700 underline decoration-slate-300 underline-offset-4 transition hover:text-slate-950 hover:decoration-slate-500" %>
    <span aria-hidden="true" class="text-slate-300">/</span>
    <span class="font-medium text-slate-950"><%= @loan_application.application_number %></span>
  </nav>

  <section class="rounded-3xl border border-slate-200 bg-white p-8 shadow-sm sm:p-10">
    <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
      <div class="space-y-3">
        <p class="text-sm font-semibold uppercase tracking-[0.24em] text-slate-500">Loan application</p>
        <h1 class="text-3xl font-semibold tracking-tight text-slate-950"><%= @loan_application.application_number %></h1>
        <p class="text-sm leading-6 text-slate-600">
          Use this application workspace to capture and maintain the minimum pre-decision details needed for review while keeping borrower context and application status visible.
        </p>
      </div>
      <%= render Shared::StatusBadgeComponent.new(label: @loan_application.status_label, tone: @loan_application.status_tone) %>
    </div>

    <dl class="mt-8 grid gap-5 rounded-2xl border border-slate-200 bg-slate-50 p-6 sm:grid-cols-2">
      <div>
        <dt class="text-sm font-medium text-slate-500">Borrower</dt>
        <dd class="mt-2 text-lg font-semibold text-slate-950"><%= link_to @loan_application.borrower.full_name, borrower_path(@loan_application.borrower), class: "underline decoration-slate-300 underline-offset-4 transition hover:decoration-slate-500" %></dd>
      </div>

      <div>
        <dt class="text-sm font-medium text-slate-500">Current status</dt>
        <dd class="mt-2 text-lg font-semibold text-slate-950"><%= @loan_application.status_label %></dd>
      </div>

      <div>
        <dt class="text-sm font-medium text-slate-500">Borrower snapshot</dt>
        <dd class="mt-2 text-lg font-semibold text-slate-950"><%= @loan_application.borrower_full_name_snapshot || @loan_application.borrower.full_name %></dd>
      </div>

      <div>
        <dt class="text-sm font-medium text-slate-500">Snapshot phone number</dt>
        <dd class="mt-2 text-lg font-semibold text-slate-950"><%= @loan_application.borrower_phone_number_snapshot || @loan_application.borrower.phone_number_normalized %></dd>
      </div>
    </dl>
  </section>

  <section class="rounded-3xl border border-slate-200 bg-white p-8 shadow-sm sm:p-10">
    <div class="space-y-3">
      <h2 class="text-2xl font-semibold tracking-tight text-slate-950">Review workflow</h2>
      <p class="text-sm leading-6 text-slate-600">
        Every application follows the same fixed review path. The active step comes from the ordered review records shown below.
      </p>
    </div>

    <dl class="mt-8 grid gap-5 rounded-2xl border border-slate-200 bg-slate-50 p-6 sm:grid-cols-2">
      <div>
        <dt class="text-sm font-medium text-slate-500">Current application status</dt>
        <dd class="mt-2 flex items-center gap-3 text-lg font-semibold text-slate-950">
          <span><%= @loan_application.status_label %></span>
          <%= render Shared::StatusBadgeComponent.new(label: @loan_application.status_label, tone: @loan_application.status_tone) %>
        </dd>
      </div>

      <div>
        <dt class="text-sm font-medium text-slate-500">Active review step</dt>
        <dd class="mt-2 text-lg font-semibold text-slate-950">
          <%= if active_review_step.present?
                active_review_step.label
              elsif workflow_complete
                "No active step"
              else
                "Not initialized yet"
              end %>
        </dd>
      </div>
    </dl>

    <div class="mt-8 rounded-2xl border border-slate-200 bg-slate-50 p-6">
      <% if active_review_step.present? && editable %>
        <div class="space-y-3">
          <h3 class="text-lg font-semibold text-slate-950">Current step actions</h3>
          <p class="text-sm leading-6 text-slate-600">
            <% if waiting_for_details %>
              This application is waiting for details before review can continue. Once the needed information arrives, approve the same active step to move the workflow forward.
            <% else %>
              Only the current active review step can be updated. Earlier and later steps stay read-only until the workflow reaches them in order.
            <% end %>
          </p>
          <div class="flex flex-wrap gap-3">
            <%= button_to "Approve step", approve_loan_application_review_step_path(@loan_application, active_review_step, from: detail_source), method: :patch, class: "inline-flex items-center justify-center rounded-xl bg-slate-950 px-5 py-3 text-sm font-semibold text-white transition hover:bg-slate-800 focus:outline-none focus:ring-2 focus:ring-slate-950/15 focus:ring-offset-2 cursor-pointer" %>
            <% unless waiting_for_details %>
              <%= button_to "Request details", request_details_loan_application_review_step_path(@loan_application, active_review_step, from: detail_source), method: :patch, class: "inline-flex items-center justify-center rounded-xl border border-slate-300 px-5 py-3 text-sm font-semibold text-slate-700 transition hover:border-slate-400 hover:text-slate-950 focus:outline-none focus:ring-2 focus:ring-slate-950/15 focus:ring-offset-2 cursor-pointer" %>
            <% end %>
          </div>
        </div>
      <% elsif active_review_step.present? %>
        <p class="text-sm leading-6 text-slate-600">
          Review steps are locked because this application has already crossed a final decision boundary.
        </p>
      <% elsif workflow_complete %>
        <p class="text-sm leading-6 text-slate-600">
          Every review step is already complete. Use the application decision section below to record the final outcome.
        </p>
      <% else %>
        <p class="text-sm leading-6 text-slate-600">
          Review steps will become actionable here once the workflow is initialized for this application.
        </p>
      <% end %>
    </div>

    <ol class="mt-8 space-y-4">
      <% @loan_application.review_steps.each do |review_step| %>
        <% is_active = review_step == active_review_step %>
        <% step_summary = if is_active && review_step.status == "waiting for details"
                            "Waiting for details before review can continue."
                          elsif is_active
                            "Active now in the current workflow."
                          elsif review_step.final?
                            "Completed in the review workflow."
                          else
                            "Queued by workflow order until the earlier steps are resolved."
                          end %>
        <% step_state_label = if is_active && review_step.status == "waiting for details"
                                "Waiting for details"
                              elsif is_active
                                "Current stage"
                              elsif review_step.final?
                                "Completed"
                              else
                                "Awaiting turn"
                              end %>
        <li class="flex flex-col gap-4 rounded-2xl border border-slate-200 px-5 py-4 sm:flex-row sm:items-start sm:justify-between">
          <div class="space-y-2">
            <p class="text-sm font-semibold uppercase tracking-[0.18em] text-slate-500">Step <%= review_step.position %></p>
            <p class="text-lg font-semibold text-slate-950"><%= review_step.label %></p>
            <p class="text-sm leading-6 text-slate-600"><%= step_summary %></p>
          </div>

          <div class="flex flex-col items-start gap-3 sm:items-end">
            <%= render Shared::StatusBadgeComponent.new(label: review_step.status_label, tone: review_step.status_tone) %>
            <p class="text-sm font-medium text-slate-600"><%= step_state_label %></p>
          </div>
        </li>
      <% end %>
    </ol>
  </section>

  <section id="borrower-lending-context" class="rounded-3xl border border-slate-200 bg-white p-8 shadow-sm sm:p-10">
    <div class="flex flex-col gap-4 border-b border-slate-200 pb-6 lg:flex-row lg:items-start lg:justify-between">
      <div class="max-w-3xl space-y-3">
        <h2 class="text-2xl font-semibold tracking-tight text-slate-950">Borrower lending context</h2>
        <p class="text-sm leading-6 text-slate-600">
          Review the borrower&apos;s linked lending history here without leaving the application workspace, then open the full borrower profile when you need deeper record context.
        </p>
      </div>

      <%= link_to "View full borrower profile", borrower_path(@loan_application.borrower), class: "inline-flex items-center justify-center rounded-xl border border-slate-300 px-5 py-3 text-sm font-semibold text-slate-700 transition hover:border-slate-400 hover:text-slate-950" %>
    </div>

    <div class="mt-8 grid gap-4 lg:grid-cols-[minmax(0,2fr)_minmax(0,1fr)]">
      <article class="rounded-2xl border border-slate-200 bg-slate-50 p-6">
        <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-500">Current lending context</p>
        <h3 class="mt-3 text-xl font-semibold text-slate-950"><%= borrower_context.headline %></h3>
        <p class="mt-2 text-sm leading-6 text-slate-600"><%= borrower_context.summary %></p>
        <dl class="mt-5 grid gap-4 sm:grid-cols-2">
          <div>
            <dt class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-500">Applications linked</dt>
            <dd class="mt-2 text-2xl font-semibold text-slate-950"><%= borrower_context.application_count %></dd>
          </div>
          <div>
            <dt class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-500">Loans linked</dt>
            <dd class="mt-2 text-2xl font-semibold text-slate-950"><%= borrower_context.loan_count %></dd>
          </div>
        </dl>
      </article>

      <article class="rounded-2xl border border-slate-200 bg-slate-50 p-6">
        <div class="flex flex-wrap items-start justify-between gap-3">
          <div class="space-y-2">
            <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-500">Application readiness</p>
            <p class="text-lg font-semibold text-slate-950"><%= borrower_eligibility.headline %></p>
          </div>
          <%= render Shared::StatusBadgeComponent.new(
            label: borrower_eligibility.eligible? ? "Eligible" : "Blocked",
            tone: borrower_eligibility.eligible? ? :success : :warning
          ) %>
        </div>
        <p class="mt-3 text-sm leading-6 text-slate-600"><%= borrower_eligibility.message %></p>
      </article>
    </div>

    <% if @borrower_history_records.any? %>
      <div class="mt-8 space-y-4">
        <% @borrower_history_records.each do |record| %>
          <article class="flex flex-col gap-4 rounded-2xl border border-slate-200 bg-slate-50 p-5 lg:flex-row lg:items-center lg:justify-between">
            <div class="space-y-2">
              <div class="flex flex-wrap items-center gap-3">
                <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-500"><%= record.label %></p>
                <%= render Shared::StatusBadgeComponent.new(label: record.status_label, tone: record.status_tone) %>
              </div>
              <p class="text-lg font-semibold text-slate-950">
                <%= link_to record.identifier, record.path, class: "underline decoration-slate-300 underline-offset-4 transition hover:text-slate-700 hover:decoration-slate-500" %>
              </p>
              <p class="text-sm text-slate-600"><%= record.relevant_label %></p>
            </div>

            <div class="flex items-center gap-3">
              <%= link_to "Open #{record.label.downcase}", record.path, class: "inline-flex items-center justify-center rounded-xl border border-slate-300 px-4 py-2 text-sm font-semibold text-slate-700 transition hover:border-slate-400 hover:text-slate-950" %>
            </div>
          </article>
        <% end %>
      </div>
    <% else %>
      <div class="mt-8 rounded-2xl border border-dashed border-slate-300 bg-slate-50 p-6">
        <p class="text-base font-semibold text-slate-950">No prior lending history for this borrower beyond the current application</p>
        <p class="mt-2 text-sm leading-6 text-slate-600">
          Keep reviewing this application here, or open the full borrower profile if you need to confirm identity and record ownership before making a decision.
        </p>
      </div>
    <% end %>
  </section>

  <section class="rounded-3xl border border-slate-200 bg-white p-8 shadow-sm sm:p-10">
    <div class="space-y-3">
      <h2 class="text-2xl font-semibold tracking-tight text-slate-950">Application decision</h2>
      <p class="text-sm leading-6 text-slate-600">
        Final application outcomes stay visible here so the decision remains traceable without losing the surrounding borrower and workflow context.
      </p>
    </div>

    <% if final_decision %>
      <div class="mt-8 rounded-2xl border border-slate-200 bg-slate-50 p-6">
        <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
          <div class="space-y-3">
            <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-500">Final outcome</p>
            <h3 class="text-xl font-semibold text-slate-950"><%= @loan_application.status_label %></h3>
            <p class="text-sm leading-6 text-slate-600">
              This application is now locked for further review and detail changes.
            </p>
          </div>

          <%= render Shared::StatusBadgeComponent.new(label: @loan_application.status_label, tone: @loan_application.status_tone) %>
        </div>

        <dl class="mt-6 grid gap-5 sm:grid-cols-2">
          <div>
            <dt class="text-sm font-medium text-slate-500">Decision recorded</dt>
            <dd class="mt-2 text-base font-semibold text-slate-950"><%= @loan_application.updated_at.to_fs(:long) %></dd>
          </div>

          <% if @loan_application.decision_notes.present? %>
            <div class="sm:col-span-2">
              <dt class="text-sm font-medium text-slate-500">Decision notes</dt>
              <dd class="mt-2 text-base font-semibold text-slate-950"><%= @loan_application.decision_notes_display %></dd>
            </div>
          <% end %>
        </dl>
      </div>
    <% elsif editable %>
      <div class="mt-8 rounded-2xl border border-slate-200 bg-slate-50 p-6">
        <div class="space-y-4">
          <p class="text-sm leading-6 text-slate-600">
            <% if approvable %>
              All review steps are approved. You can now record the final application outcome here.
            <% else %>
              Approval becomes available once review has started and every review step is approved. Rejection and cancellation remain available while the application is still pre-decision.
            <% end %>
          </p>

          <div class="flex flex-wrap gap-3">
            <% if approvable %>
              <%= button_to "Approve application", approve_loan_application_path(@loan_application, from: detail_source), method: :patch, class: "inline-flex items-center justify-center rounded-xl bg-slate-950 px-5 py-3 text-sm font-semibold text-white transition hover:bg-slate-800 focus:outline-none focus:ring-2 focus:ring-slate-950/15 focus:ring-offset-2 cursor-pointer" %>
            <% end %>

            <%= button_to "Reject application", reject_loan_application_path(@loan_application, from: detail_source), method: :patch, data: { turbo_confirm: "Are you sure you want to reject this application? This action cannot be undone." }, class: "inline-flex items-center justify-center rounded-xl border border-rose-300 px-5 py-3 text-sm font-semibold text-rose-700 transition hover:border-rose-400 hover:text-rose-800 focus:outline-none focus:ring-2 focus:ring-rose-500/15 focus:ring-offset-2 cursor-pointer" %>

            <%= button_to "Cancel application", cancel_loan_application_path(@loan_application, from: detail_source), method: :patch, data: { turbo_confirm: "Are you sure you want to cancel this application? This action cannot be undone." }, class: "inline-flex items-center justify-center rounded-xl border border-slate-300 px-5 py-3 text-sm font-semibold text-slate-700 transition hover:border-slate-400 hover:text-slate-950 focus:outline-none focus:ring-2 focus:ring-slate-950/15 focus:ring-offset-2 cursor-pointer" %>
          </div>
        </div>
      </div>
    <% end %>
  </section>

  <% if @loan_application.status == "approved" && linked_loan.present? %>
    <section class="rounded-3xl border border-slate-200 bg-white p-8 shadow-sm sm:p-10">
      <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
        <div class="space-y-3">
          <h2 class="text-2xl font-semibold tracking-tight text-slate-950">Linked loan</h2>
          <p class="text-sm leading-6 text-slate-600">
            A loan has been created from this approved application.
          </p>
        </div>

        <%= render Shared::StatusBadgeComponent.new(label: linked_loan.status_label, tone: linked_loan.status_tone) %>
      </div>

      <dl class="mt-8 grid gap-5 rounded-2xl border border-slate-200 bg-slate-50 p-6 sm:grid-cols-2">
        <div>
          <dt class="text-sm font-medium text-slate-500">Loan number</dt>
          <dd class="mt-2 text-lg font-semibold text-slate-950"><%= linked_loan.loan_number %></dd>
        </div>

        <div>
          <dt class="text-sm font-medium text-slate-500">Lifecycle state</dt>
          <dd class="mt-2 text-lg font-semibold text-slate-950"><%= linked_loan.status_label %></dd>
        </div>

        <div class="sm:col-span-2">
          <dt class="text-sm font-medium text-slate-500">Open the loan</dt>
          <dd class="mt-2">
            <%= link_to "View loan → #{linked_loan.loan_number}", loan_path(linked_loan), class: "inline-flex items-center justify-center rounded-xl border border-slate-300 px-4 py-2 text-sm font-semibold text-slate-700 transition hover:border-slate-400 hover:text-slate-950" %>
          </dd>
        </div>
      </dl>
    </section>
  <% end %>

  <section class="rounded-3xl border border-slate-200 bg-white p-8 shadow-sm sm:p-10">
    <div class="space-y-3">
      <h2 class="text-2xl font-semibold tracking-tight text-slate-950">Pre-decision application details</h2>
      <p class="text-sm leading-6 text-slate-600">
        Requested amount, tenure, repayment frequency, and proposed interest mode stay editable until the application crosses a final decision boundary.
      </p>
    </div>

    <% if @loan_application.errors.any? %>
      <div class="mt-8 rounded-2xl border border-rose-200 bg-rose-50 px-5 py-4" role="alert" aria-live="assertive" tabindex="-1">
        <h2 class="text-sm font-semibold text-rose-900">Please correct the highlighted application details.</h2>
        <ul class="mt-3 space-y-2 text-sm text-rose-700">
          <% @loan_application.errors.full_messages.each do |message| %>
            <li><p><%= message %></p></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <% unless editable %>
      <div class="mt-8 rounded-2xl border border-amber-200 bg-amber-50 px-5 py-4">
        <p class="text-sm font-semibold text-amber-900">These request details can no longer be edited after a final decision.</p>
        <p class="mt-2 text-sm leading-6 text-amber-800">
          The borrower link and application status remain visible here for orientation, but decision-sensitive request details are now locked.
        </p>
      </div>
    <% end %>

    <%= render "form", loan_application: @loan_application, editable: editable, detail_source: detail_source %>
  </section>

  <section class="rounded-3xl border border-slate-200 bg-white p-8 shadow-sm sm:p-10">
    <h2 class="text-2xl font-semibold tracking-tight text-slate-950">Current request summary</h2>
    <dl class="mt-8 grid gap-5 rounded-2xl border border-slate-200 bg-slate-50 p-6 sm:grid-cols-2">
      <div>
        <dt class="text-sm font-medium text-slate-500">Requested amount</dt>
        <dd class="mt-2 text-lg font-semibold text-slate-950"><%= @loan_application.requested_amount_display %></dd>
      </div>

      <div>
        <dt class="text-sm font-medium text-slate-500">Requested tenure</dt>
        <dd class="mt-2 text-lg font-semibold text-slate-950"><%= @loan_application.requested_tenure_display %></dd>
      </div>

      <div>
        <dt class="text-sm font-medium text-slate-500">Requested repayment frequency</dt>
        <dd class="mt-2 text-lg font-semibold text-slate-950"><%= @loan_application.requested_repayment_frequency.present? ? @loan_application.requested_repayment_frequency_label : "Not provided yet" %></dd>
      </div>

      <div>
        <dt class="text-sm font-medium text-slate-500">Proposed interest mode</dt>
        <dd class="mt-2 text-lg font-semibold text-slate-950"><%= @loan_application.proposed_interest_mode.present? ? @loan_application.proposed_interest_mode_label : "Not provided yet" %></dd>
      </div>

      <div class="sm:col-span-2">
        <dt class="text-sm font-medium text-slate-500">Review notes</dt>
        <dd class="mt-2 text-lg font-semibold text-slate-950"><%= @loan_application.request_notes_display %></dd>
      </div>
    </dl>
  </section>
</section>
