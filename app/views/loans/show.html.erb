<% content_for :title, "#{@loan.loan_number} | lending_rails" %>

<% editable = @loan.editable_details? %>
<% detail_source = params[:from].presence %>
<% detail_from_loans = detail_source == "loans" %>
<% selected_interest_mode = @loan.interest_mode.presence %>
<% show_rate_input = selected_interest_mode.blank? || selected_interest_mode == "rate" %>
<% show_total_interest_input = selected_interest_mode.blank? || selected_interest_mode == "total_interest_amount" %>
<% document_form = @document_upload || @loan.document_uploads.build(uploaded_by: Current.user) %>
<% active_documents = @loan.active_documents %>
<% superseded_documents = @loan.document_uploads.superseded.ordered %>
<% all_documents = @loan.document_uploads.ordered %>

<section class="mx-auto flex w-full max-w-5xl flex-1 flex-col gap-8">
  <nav aria-label="Breadcrumb" class="flex flex-wrap items-center gap-3 text-sm text-slate-600">
    <%= link_to "Workspace", root_path, class: "font-medium text-slate-700 underline decoration-slate-300 underline-offset-4 transition hover:text-slate-950 hover:decoration-slate-500" %>
    <span aria-hidden="true" class="text-slate-300">/</span>
    <% if detail_from_loans %>
      <%= link_to "Loans", loans_path, class: "font-medium text-slate-700 underline decoration-slate-300 underline-offset-4 transition hover:text-slate-950 hover:decoration-slate-500" %>
      <span aria-hidden="true" class="text-slate-300">/</span>
    <% end %>
    <%= link_to "Borrowers", borrowers_path, class: "font-medium text-slate-700 underline decoration-slate-300 underline-offset-4 transition hover:text-slate-950 hover:decoration-slate-500" %>
    <span aria-hidden="true" class="text-slate-300">/</span>
    <%= link_to @loan.borrower.full_name, borrower_path(@loan.borrower), class: "font-medium text-slate-700 underline decoration-slate-300 underline-offset-4 transition hover:text-slate-950 hover:decoration-slate-500" %>
    <span aria-hidden="true" class="text-slate-300">/</span>
    <span class="font-medium text-slate-950"><%= @loan.loan_number %></span>
  </nav>

  <section class="rounded-3xl border border-slate-200 bg-white p-8 shadow-sm sm:p-10">
    <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
      <div class="space-y-3">
        <p class="text-sm font-semibold uppercase tracking-[0.24em] text-slate-500">Loan</p>
        <h1 class="text-3xl font-semibold tracking-tight text-slate-950"><%= @loan.loan_number %></h1>
        <p class="text-sm leading-6 text-slate-600">
          Loans stay operationally distinct from disbursement so lifecycle state, borrower snapshot context, and the linked application remain visible before downstream execution stories add guarded actions.
        </p>
      </div>
      <%= render Shared::StatusBadgeComponent.new(label: @loan.status_label, tone: @loan.status_tone) %>
    </div>

    <dl class="mt-8 grid gap-5 rounded-2xl border border-slate-200 bg-slate-50 p-6 sm:grid-cols-2">
      <div>
        <dt class="text-sm font-medium text-slate-500">Borrower</dt>
        <dd class="mt-2 text-lg font-semibold text-slate-950"><%= link_to @loan.borrower.full_name, borrower_path(@loan.borrower), class: "underline decoration-slate-300 underline-offset-4 transition hover:decoration-slate-500" %></dd>
      </div>

      <div>
        <dt class="text-sm font-medium text-slate-500">Current lifecycle state</dt>
        <dd class="mt-2 text-lg font-semibold text-slate-950"><%= @loan.status_label %></dd>
      </div>

      <div>
        <dt class="text-sm font-medium text-slate-500">Borrower snapshot</dt>
        <dd class="mt-2 text-lg font-semibold text-slate-950"><%= @loan.borrower_full_name_display %></dd>
      </div>

      <div>
        <dt class="text-sm font-medium text-slate-500">Snapshot phone number</dt>
        <dd class="mt-2 text-lg font-semibold text-slate-950"><%= @loan.borrower_phone_number_display %></dd>
      </div>

      <% if @loan.loan_application.present? %>
        <div>
          <dt class="text-sm font-medium text-slate-500">Linked application</dt>
          <dd class="mt-2 text-lg font-semibold text-slate-950"><%= link_to @loan.loan_application.application_number, loan_application_path(@loan.loan_application), class: "underline decoration-slate-300 underline-offset-4 transition hover:decoration-slate-500" %></dd>
        </div>
      <% end %>

      <div>
        <dt class="text-sm font-medium text-slate-500">Created on</dt>
        <dd class="mt-2 text-lg font-semibold text-slate-950"><%= @loan.created_at.to_fs(:long) %></dd>
      </div>
    </dl>

    <dl class="mt-8 grid gap-5 rounded-2xl border border-slate-200 bg-white p-6 sm:grid-cols-2">
      <div>
        <dt class="text-sm font-medium text-slate-500">Next lifecycle stage</dt>
        <dd class="mt-2 text-lg font-semibold text-slate-950"><%= @loan.next_lifecycle_stage_label %></dd>
      </div>

      <div class="sm:col-span-2">
        <dt class="text-sm font-medium text-slate-500">Lifecycle guidance</dt>
        <dd class="mt-2 text-base leading-7 text-slate-600"><%= @loan.next_lifecycle_stage_guidance %></dd>
      </div>
    </dl>

    <% if @loan.may_begin_documentation? %>
      <div class="mt-8 rounded-2xl border border-slate-200 bg-slate-50 p-6">
        <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
          <div class="space-y-2">
            <h2 class="text-xl font-semibold text-slate-950">Next valid action</h2>
            <p class="text-sm leading-6 text-slate-600">
              This loan is still in its editable pre-disbursement stage. Begin documentation once the loan details below are complete and reviewed.
            </p>
          </div>

          <%= button_to "Begin documentation",
              begin_documentation_loan_path(@loan, from: detail_source),
              method: :patch,
              data: {
                turbo_confirm: "Begin documentation for #{@loan.loan_number}? This moves the loan into documentation in progress."
              },
              class: "inline-flex cursor-pointer items-center justify-center rounded-xl bg-slate-950 px-5 py-3 text-sm font-semibold text-white transition hover:bg-slate-800 focus:outline-none focus:ring-2 focus:ring-slate-950/15 focus:ring-offset-2" %>
        </div>
      </div>
    <% end %>
  </section>

  <section id="loan-documentation" class="rounded-3xl border border-slate-200 bg-white p-8 shadow-sm sm:p-10">
    <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
      <div class="space-y-3">
        <h2 class="text-2xl font-semibold tracking-tight text-slate-950">Loan documentation</h2>
        <p class="text-sm leading-6 text-slate-600">
          Documentation is a distinct operational stage between loan setup and disbursement readiness, and every upload remains part of the lending record history.
        </p>
      </div>

      <% if @loan.may_complete_documentation? %>
        <%= button_to "Complete documentation",
            complete_documentation_loan_path(@loan, from: detail_source),
            method: :patch,
            data: {
              turbo_confirm: "Complete documentation for #{@loan.loan_number}? This moves the loan into ready for disbursement."
            },
            class: "inline-flex cursor-pointer items-center justify-center rounded-xl bg-slate-950 px-5 py-3 text-sm font-semibold text-white transition hover:bg-slate-800 focus:outline-none focus:ring-2 focus:ring-slate-950/15 focus:ring-offset-2" %>
      <% end %>
    </div>

    <% if document_form.errors.any? %>
      <div class="mt-8 rounded-2xl border border-rose-200 bg-rose-50 px-5 py-4" role="alert" aria-live="assertive">
        <p class="text-sm font-semibold text-rose-900">Document could not be uploaded.</p>
        <ul class="mt-3 space-y-2 text-sm text-rose-700">
          <% document_form.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <% if @loan.documentation_uploadable? %>
      <div class="mt-8 rounded-2xl border border-slate-200 bg-slate-50 p-6">
        <h3 class="text-lg font-semibold text-slate-950">Upload supporting documents</h3>
        <p class="mt-2 text-sm leading-6 text-slate-600">
          Upload the current active document for this lending record. Replacements keep prior versions in history instead of overwriting them.
        </p>

        <%= form_with url: loan_documents_path(@loan, from: detail_source), scope: :document, class: "mt-6 space-y-6" do |form| %>
          <div class="grid gap-6 lg:grid-cols-2">
            <div class="space-y-2 lg:col-span-2">
              <%= form.label :file, "Document file", class: "block text-sm font-medium text-slate-700" %>
              <%= form.file_field :file,
                  required: true,
                  direct_upload: true,
                  class: "block w-full rounded-xl border border-slate-300 bg-white px-4 py-3 text-sm text-slate-900 shadow-sm transition file:mr-4 file:cursor-pointer file:rounded-lg file:border-0 file:bg-slate-950 file:px-4 file:py-2 file:text-sm file:font-semibold file:text-white hover:file:bg-slate-800 focus:border-slate-400 focus:outline-none focus:ring-2 focus:ring-slate-950/10" %>
            </div>

            <div class="space-y-2">
              <%= form.label :file_name, "Document name", class: "block text-sm font-medium text-slate-700" %>
              <%= form.text_field :file_name,
                  value: document_form.file_name,
                  required: true,
                  class: "block w-full rounded-xl border border-slate-300 bg-white px-4 py-3 text-sm text-slate-900 shadow-sm transition focus:border-slate-400 focus:outline-none focus:ring-2 focus:ring-slate-950/10" %>
            </div>

            <div class="space-y-2 lg:col-span-2">
              <%= form.label :description, "Description", class: "block text-sm font-medium text-slate-700" %>
              <%= form.text_area :description,
                  value: document_form.description,
                  rows: 3,
                  class: "block w-full rounded-2xl border border-slate-300 bg-white px-4 py-3 text-sm text-slate-900 shadow-sm transition focus:border-slate-400 focus:outline-none focus:ring-2 focus:ring-slate-950/10" %>
            </div>
          </div>

          <div class="flex justify-end">
            <%= form.submit "Upload document", class: "inline-flex cursor-pointer items-center justify-center rounded-xl bg-slate-950 px-5 py-3 text-sm font-semibold text-white transition hover:bg-slate-800 focus:outline-none focus:ring-2 focus:ring-slate-950/15 focus:ring-offset-2" %>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="mt-8 rounded-2xl border border-amber-200 bg-amber-50 px-5 py-4">
        <p class="text-sm font-semibold text-amber-900">Documents can no longer be uploaded after disbursement.</p>
        <p class="mt-2 text-sm leading-6 text-amber-800">
          Existing documentation remains visible for audit history, but the upload window closes once the loan crosses into post-disbursement servicing.
        </p>
      </div>
    <% end %>

    <div class="mt-8 space-y-4">
      <h3 class="text-lg font-semibold text-slate-950">Active documents</h3>

      <% if all_documents.empty? %>
        <div class="rounded-2xl border border-dashed border-slate-300 bg-slate-50 px-5 py-6">
          <p class="text-sm font-medium text-slate-700">No documents uploaded yet.</p>
          <p class="mt-2 text-sm leading-6 text-slate-600">
            Upload supporting files here once documentation review begins.
          </p>
        </div>
      <% else %>
        <div class="space-y-4">
          <% active_documents.each do |document| %>
            <article class="rounded-2xl border border-slate-200 bg-white p-5">
              <div class="flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
                <div class="space-y-2">
                  <p class="text-base font-semibold text-slate-950">
                    <%= link_to document.file_name,
                        rails_blob_path(document.file, disposition: "attachment"),
                        class: "underline decoration-slate-300 underline-offset-4 transition hover:decoration-slate-500" %>
                  </p>
                  <p class="text-sm leading-6 text-slate-600"><%= document.description.presence || "No description provided." %></p>
                  <dl class="grid gap-2 text-sm text-slate-600 sm:grid-cols-3">
                    <div>
                      <dt class="font-medium text-slate-500">Uploaded</dt>
                      <dd><%= document.created_at.to_fs(:long) %></dd>
                    </div>
                    <div>
                      <dt class="font-medium text-slate-500">Uploaded by</dt>
                      <dd><%= document.uploaded_by.email_address %></dd>
                    </div>
                    <div>
                      <dt class="font-medium text-slate-500">Status</dt>
                      <dd>Active</dd>
                    </div>
                  </dl>
                </div>

                <% if @loan.documentation_uploadable? %>
                  <details class="w-full max-w-md rounded-2xl border border-slate-200 bg-slate-50 p-4">
                    <summary class="cursor-pointer text-sm font-semibold text-slate-900">Replace document</summary>
                    <div class="mt-4">
                      <%= form_with url: replace_document_path(document, from: detail_source), method: :patch, scope: :document, class: "space-y-4" do |form| %>
                        <div class="space-y-2">
                          <%= form.label :file, "Replacement file", class: "block text-sm font-medium text-slate-700" %>
                          <%= form.file_field :file,
                              required: true,
                              direct_upload: true,
                              class: "block w-full rounded-xl border border-slate-300 bg-white px-4 py-3 text-sm text-slate-900 shadow-sm transition file:mr-4 file:cursor-pointer file:rounded-lg file:border-0 file:bg-slate-950 file:px-4 file:py-2 file:text-sm file:font-semibold file:text-white hover:file:bg-slate-800 focus:border-slate-400 focus:outline-none focus:ring-2 focus:ring-slate-950/10" %>
                        </div>

                        <div class="space-y-2">
                          <%= form.label :file_name, "Replacement document name", class: "block text-sm font-medium text-slate-700" %>
                          <%= form.text_field :file_name,
                              value: document.file_name,
                              class: "block w-full rounded-xl border border-slate-300 bg-white px-4 py-3 text-sm text-slate-900 shadow-sm transition focus:border-slate-400 focus:outline-none focus:ring-2 focus:ring-slate-950/10" %>
                        </div>

                        <div class="space-y-2">
                          <%= form.label :description, "Replacement description", class: "block text-sm font-medium text-slate-700" %>
                          <%= form.text_area :description,
                              value: document.description,
                              rows: 2,
                              class: "block w-full rounded-2xl border border-slate-300 bg-white px-4 py-3 text-sm text-slate-900 shadow-sm transition focus:border-slate-400 focus:outline-none focus:ring-2 focus:ring-slate-950/10" %>
                        </div>

                        <div class="flex justify-end">
                          <%= form.submit "Replace document", class: "inline-flex cursor-pointer items-center justify-center rounded-xl bg-white px-4 py-2 text-sm font-semibold text-slate-900 ring-1 ring-slate-300 transition hover:bg-slate-100 focus:outline-none focus:ring-2 focus:ring-slate-950/10" %>
                        </div>
                      <% end %>
                    </div>
                  </details>
                <% end %>
              </div>
            </article>
          <% end %>
        </div>
      <% end %>
    </div>

    <% if superseded_documents.any? %>
      <details class="mt-8 rounded-2xl border border-slate-200 bg-slate-50 p-5">
        <summary class="cursor-pointer text-lg font-semibold text-slate-950">Document history</summary>
        <div class="mt-4 space-y-4">
          <% superseded_documents.each do |document| %>
            <article class="rounded-2xl border border-slate-200 bg-slate-100 p-4 text-sm text-slate-600">
              <p class="font-semibold text-slate-800"><%= document.file_name %></p>
              <p class="mt-2">Superseded <%= document.superseded_at&.to_fs(:long) || "recently" %></p>
              <% if document.superseded_by.present? %>
                <p class="mt-1">Replaced by <%= document.superseded_by.file_name %></p>
              <% end %>
            </article>
          <% end %>
        </div>
      </details>
    <% end %>
  </section>

  <section class="rounded-3xl border border-slate-200 bg-white p-8 shadow-sm sm:p-10">
    <div class="space-y-3">
      <h2 class="text-2xl font-semibold tracking-tight text-slate-950">Pre-disbursement loan details</h2>
      <p class="text-sm leading-6 text-slate-600">
        Principal, tenure, repayment frequency, interest details, and operational notes stay editable only before the loan crosses the disbursement boundary.
      </p>
    </div>

    <% if @loan.errors.any? %>
      <div class="mt-8 rounded-2xl border border-rose-200 bg-rose-50 px-5 py-4" role="alert" aria-live="assertive" tabindex="-1">
        <h2 class="text-sm font-semibold text-rose-900">Please correct the highlighted loan details.</h2>
        <ul class="mt-3 space-y-2 text-sm text-rose-700">
          <% @loan.errors.full_messages.each do |message| %>
            <li><p><%= message %></p></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <% unless editable %>
      <div class="mt-8 rounded-2xl border border-amber-200 bg-amber-50 px-5 py-4">
        <p class="text-sm font-semibold text-amber-900">These loan details can no longer be edited after disbursement.</p>
        <p class="mt-2 text-sm leading-6 text-amber-800">
          The lifecycle context remains visible here for orientation, but pre-money details are now locked to preserve the accounting boundary.
        </p>
      </div>
    <% end %>

    <%= form_with model: @loan, class: "mt-8 space-y-8", data: { controller: "interest-mode-toggle" } do |form| %>
      <% if detail_source.present? %>
        <%= hidden_field_tag :from, detail_source %>
      <% end %>

      <div class="grid gap-6 lg:grid-cols-2">
        <div class="space-y-2">
          <%= form.label :principal_amount, "Principal amount", class: "block text-sm font-medium text-slate-700" %>
          <%= form.number_field :principal_amount,
              required: editable,
              disabled: !editable,
              min: 0,
              step: "0.01",
              value: (@loan.principal_amount.present? ? format("%.2f", @loan.principal_amount.to_d) : nil),
              class: "block w-full rounded-xl border border-slate-300 bg-white px-4 py-3 text-sm text-slate-900 shadow-sm transition focus:border-slate-400 focus:outline-none focus:ring-2 focus:ring-slate-950/10 disabled:cursor-not-allowed disabled:bg-slate-100" %>
        </div>

        <div class="space-y-2">
          <%= form.label :tenure_in_months, "Tenure (months)", class: "block text-sm font-medium text-slate-700" %>
          <%= form.number_field :tenure_in_months,
              required: editable,
              disabled: !editable,
              min: 1,
              step: 1,
              class: "block w-full rounded-xl border border-slate-300 bg-white px-4 py-3 text-sm text-slate-900 shadow-sm transition focus:border-slate-400 focus:outline-none focus:ring-2 focus:ring-slate-950/10 disabled:cursor-not-allowed disabled:bg-slate-100" %>
        </div>

        <div class="space-y-2">
          <%= form.label :repayment_frequency, "Repayment frequency", class: "block text-sm font-medium text-slate-700" %>
          <%= form.select :repayment_frequency,
              Loan::REPAYMENT_FREQUENCIES.map { |value| [ value.split("-").map(&:capitalize).join("-"), value ] },
              { include_blank: "Select a repayment frequency" },
              {
                required: editable,
                disabled: !editable,
                class: "block w-full rounded-xl border border-slate-300 bg-white px-4 py-3 text-sm text-slate-900 shadow-sm transition focus:border-slate-400 focus:outline-none focus:ring-2 focus:ring-slate-950/10 disabled:cursor-not-allowed disabled:bg-slate-100"
              } %>
        </div>

        <div class="space-y-2">
          <%= form.label :interest_mode, "Interest mode", class: "block text-sm font-medium text-slate-700" %>
          <%= form.select :interest_mode,
              [
                [ "Interest rate", "rate" ],
                [ "Total interest amount", "total_interest_amount" ]
              ],
              { include_blank: "Select an interest mode" },
              {
                required: editable,
                disabled: !editable,
                class: "block w-full rounded-xl border border-slate-300 bg-white px-4 py-3 text-sm text-slate-900 shadow-sm transition focus:border-slate-400 focus:outline-none focus:ring-2 focus:ring-slate-950/10 disabled:cursor-not-allowed disabled:bg-slate-100",
                data: {
                  interest_mode_toggle_target: "mode",
                  action: "change->interest-mode-toggle#sync"
                }
              } %>
        </div>

        <div class="<%= show_rate_input ? "" : "hidden " %>space-y-2" data-interest-mode-toggle-target="rateSection">
          <%= form.label :interest_rate, "Interest rate", class: "block text-sm font-medium text-slate-700" %>
          <%= form.number_field :interest_rate,
              min: 0,
              step: "0.0001",
              disabled: !editable || selected_interest_mode != "rate",
              value: (@loan.interest_rate.present? ? format("%.4f", @loan.interest_rate) : nil),
              class: "block w-full rounded-xl border border-slate-300 bg-white px-4 py-3 text-sm text-slate-900 shadow-sm transition focus:border-slate-400 focus:outline-none focus:ring-2 focus:ring-slate-950/10 disabled:cursor-not-allowed disabled:bg-slate-100",
              data: { interest_mode_toggle_target: "rateInput" } %>
          <% if selected_interest_mode.blank? %>
            <p class="text-xs leading-5 text-slate-500">Select an interest mode to enable the matching input.</p>
          <% end %>
        </div>

        <div class="<%= show_total_interest_input ? "" : "hidden " %>space-y-2" data-interest-mode-toggle-target="amountSection">
          <%= form.label :total_interest_amount, "Total interest amount", class: "block text-sm font-medium text-slate-700" %>
          <%= form.number_field :total_interest_amount,
              min: 0,
              step: "0.01",
              disabled: !editable || selected_interest_mode != "total_interest_amount",
              value: (@loan.total_interest_amount.present? ? format("%.2f", @loan.total_interest_amount.to_d) : nil),
              class: "block w-full rounded-xl border border-slate-300 bg-white px-4 py-3 text-sm text-slate-900 shadow-sm transition focus:border-slate-400 focus:outline-none focus:ring-2 focus:ring-slate-950/10 disabled:cursor-not-allowed disabled:bg-slate-100",
              data: { interest_mode_toggle_target: "amountInput" } %>
          <% if selected_interest_mode.blank? %>
            <p class="text-xs leading-5 text-slate-500">Select an interest mode to enable the matching input.</p>
          <% end %>
        </div>

        <div class="space-y-2 lg:col-span-2">
          <%= form.label :notes, "Notes", class: "block text-sm font-medium text-slate-700" %>
          <%= form.text_area :notes,
              rows: 4,
              disabled: !editable,
              class: "block w-full rounded-2xl border border-slate-300 bg-white px-4 py-3 text-sm text-slate-900 shadow-sm transition focus:border-slate-400 focus:outline-none focus:ring-2 focus:ring-slate-950/10 disabled:cursor-not-allowed disabled:bg-slate-100" %>
        </div>
      </div>

      <% if editable %>
        <div class="flex justify-end border-t border-slate-200 pt-6">
          <%= form.submit "Save loan details", class: "inline-flex items-center justify-center rounded-xl bg-slate-950 px-5 py-3 text-sm font-semibold text-white transition hover:bg-slate-800 focus:outline-none focus:ring-2 focus:ring-slate-950/15 focus:ring-offset-2 cursor-pointer" %>
        </div>
      <% end %>
    <% end %>
  </section>

  <section class="rounded-3xl border border-slate-200 bg-white p-8 shadow-sm sm:p-10">
    <h2 class="text-2xl font-semibold tracking-tight text-slate-950">Current loan summary</h2>
    <dl class="mt-8 grid gap-5 rounded-2xl border border-slate-200 bg-slate-50 p-6 sm:grid-cols-2">
      <div>
        <dt class="text-sm font-medium text-slate-500">Principal amount</dt>
        <dd class="mt-2 text-lg font-semibold text-slate-950"><%= @loan.principal_amount_display %></dd>
