<% content_for :title, "#{@payment.loan.loan_number} · ##{@payment.installment_number} | lending_rails" %>

<% detail_source = params[:from].presence %>
<% detail_from_loans = detail_source == "loans" %>
<% loan = @payment.loan %>
<% borrower = loan.borrower %>

<section class="mx-auto flex w-full max-w-5xl flex-1 flex-col gap-8">
  <nav aria-label="Breadcrumb" class="flex flex-wrap items-center gap-3 text-sm text-slate-600">
    <%= link_to "Workspace", root_path, class: "font-medium text-slate-700 underline decoration-slate-300 underline-offset-4 transition hover:text-slate-950 hover:decoration-slate-500" %>
    <span aria-hidden="true" class="text-slate-300">/</span>
    <% if detail_from_loans %>
      <%= link_to "Loans", loans_path, class: "font-medium text-slate-700 underline decoration-slate-300 underline-offset-4 transition hover:text-slate-950 hover:decoration-slate-500" %>
      <span aria-hidden="true" class="text-slate-300">/</span>
      <%= link_to loan.loan_number, loan_path(loan, from: "loans"), class: "font-medium text-slate-700 underline decoration-slate-300 underline-offset-4 transition hover:text-slate-950 hover:decoration-slate-500" %>
    <% else %>
      <%= link_to "Payments", payments_path, class: "font-medium text-slate-700 underline decoration-slate-300 underline-offset-4 transition hover:text-slate-950 hover:decoration-slate-500" %>
    <% end %>
    <span aria-hidden="true" class="text-slate-300">/</span>
    <span class="font-medium text-slate-950"><%= loan.loan_number %> · #<%= @payment.installment_number %></span>
  </nav>

  <section class="rounded-3xl border border-slate-200 bg-white p-8 shadow-sm sm:p-10">
    <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
      <div class="space-y-3">
        <p class="text-sm font-semibold uppercase tracking-[0.24em] text-slate-500">Payment</p>
        <h1 class="text-3xl font-semibold tracking-tight text-slate-950">
          <%= loan.loan_number %> · Installment #<%= @payment.installment_number %>
        </h1>
        <p class="text-sm leading-6 text-slate-600">
          <% if @payment.completed? %>
            This payment has been recorded. The completion details below are locked and preserved as financial history.
          <% else %>
            Verify the installment facts below — loan, borrower, amounts, and due date — before recording this payment as completed through the guarded action.
          <% end %>
        </p>
      </div>
      <%= render Shared::StatusBadgeComponent.new(label: @payment.status_label, tone: @payment.status_tone) %>
    </div>

    <% if @payment.editable? %>
      <section aria-labelledby="payment-completion-heading" class="mt-8 rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
        <h2 id="payment-completion-heading" class="text-lg font-semibold text-slate-950">Record completed payment</h2>
        <p class="mt-2 text-sm leading-6 text-slate-600">
          Completing this payment locks the record. The payment date, mode, and notes cannot be edited afterward.
        </p>

        <%= form_with model: @payment, url: mark_completed_payment_path(@payment, from: params[:from]), method: :patch, scope: :payment, local: true, html: { class: "mt-6 space-y-5" } do |form| %>
          <div class="grid gap-5 sm:grid-cols-2">
            <div>
              <%= form.label :payment_date, "Payment date", class: "block text-sm font-medium text-slate-700" %>
              <%= form.date_field :payment_date,
                    required: true,
                    max: Date.current,
                    value: params.dig(:payment, :payment_date) || Date.current,
                    class: "mt-2 block w-full rounded-xl border border-slate-300 bg-white px-4 py-3 text-sm text-slate-900 shadow-sm transition focus:border-slate-400 focus:outline-none focus:ring-2 focus:ring-slate-950/10" %>
            </div>

            <div>
              <%= form.label :payment_mode, "Payment mode", class: "block text-sm font-medium text-slate-700" %>
              <%= form.select :payment_mode,
                    Payment::PAYMENT_MODES.map { |m| [ m.humanize, m ] },
                    { include_blank: "Select a mode", selected: params.dig(:payment, :payment_mode) },
                    required: true,
                    class: "mt-2 block w-full rounded-xl border border-slate-300 bg-white px-4 py-3 text-sm text-slate-900 shadow-sm transition focus:border-slate-400 focus:outline-none focus:ring-2 focus:ring-slate-950/10" %>
            </div>
          </div>

          <div>
            <%= form.label :notes, "Notes", class: "block text-sm font-medium text-slate-700" %>
            <%= form.text_area :notes,
                  rows: 3,
                  value: params.dig(:payment, :notes),
                  class: "mt-2 block w-full rounded-xl border border-slate-300 bg-white px-4 py-3 text-sm text-slate-900 shadow-sm transition focus:border-slate-400 focus:outline-none focus:ring-2 focus:ring-slate-950/10" %>
            <p class="mt-1 text-xs text-slate-500">Optional context that will be stored alongside this completion record.</p>
          </div>

          <div class="flex flex-col gap-3 sm:flex-row sm:items-center">
            <%= form.submit "Mark payment complete",
                  data: {
                    turbo_confirm: "Mark this payment as completed?\n\nThis will lock the payment date, mode, and notes — these fields cannot be edited afterward."
                  },
                  class: "inline-flex cursor-pointer items-center justify-center rounded-xl bg-slate-950 px-5 py-3 text-sm font-semibold text-white transition hover:bg-slate-800 focus:outline-none focus:ring-2 focus:ring-slate-950/15 focus:ring-offset-2" %>
            <% cancel_path = detail_from_loans ? loan_path(loan, from: "loans") : payments_path %>
            <%= link_to "Cancel", cancel_path, class: "inline-flex items-center justify-center rounded-xl border border-slate-300 px-5 py-3 text-sm font-semibold text-slate-700 transition hover:border-slate-400 hover:text-slate-950" %>
          </div>
        <% end %>
      </section>
    <% elsif @payment.completed? %>
      <section aria-labelledby="payment-completed-heading" class="mt-8 rounded-2xl border border-emerald-200 bg-emerald-50 p-6">
        <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
          <div class="space-y-2">
            <h2 id="payment-completed-heading" class="text-lg font-semibold text-slate-950">Payment completed</h2>
            <p class="text-sm leading-6 text-slate-700">
              This payment was recorded on <%= @payment.completed_at&.to_fs(:long) %>. The payment date, mode, and notes are now locked and cannot be edited.
            </p>
          </div>
          <%= render Shared::StatusBadgeComponent.new(label: "Completed", tone: :success) %>
        </div>

        <dl class="mt-6 grid gap-5 sm:grid-cols-2">
          <div>
            <dt class="text-sm font-medium text-slate-500">Payment date</dt>
            <dd class="mt-2 text-base font-semibold text-slate-950"><%= @payment.payment_date&.to_fs(:long) || "—" %></dd>
          </div>
          <div>
            <dt class="text-sm font-medium text-slate-500">Payment mode</dt>
            <dd class="mt-2 text-base font-semibold text-slate-950"><%= @payment.payment_mode_label || "—" %></dd>
          </div>
          <div>
            <dt class="text-sm font-medium text-slate-500">Completed at</dt>
            <dd class="mt-2 text-base font-semibold text-slate-950"><%= @payment.completed_at&.to_fs(:long) || "—" %></dd>
          </div>
          <div>
            <dt class="text-sm font-medium text-slate-500">Completed by</dt>
            <dd class="mt-2 text-base font-semibold text-slate-950">
              <%
                last_version = @payment.versions.where(event: "update").last
                whodunnit = last_version&.whodunnit
                completed_by_user = whodunnit.present? ? User.find_by(id: whodunnit) : nil
              %>
              <%= completed_by_user&.email_address || "—" %>
            </dd>
          </div>
          <div>
            <dt class="text-sm font-medium text-slate-500">Payment invoice</dt>
            <dd class="mt-2 text-base font-semibold text-slate-950"><%= @payment.invoice&.invoice_number || "—" %></dd>
          </div>
          <div class="sm:col-span-2">
            <dt class="text-sm font-medium text-slate-500">Notes</dt>
            <dd class="mt-2 text-base leading-6 text-slate-800"><%= @payment.notes.presence || "—" %></dd>
          </div>
        </dl>
      </section>
    <% end %>

    <div class="mt-8 rounded-2xl border border-slate-200 bg-slate-50 p-6">
      <p class="text-sm font-medium text-slate-500">Due date</p>
      <p class="mt-2 text-xl font-semibold text-slate-950"><%= @payment.due_date.to_fs(:long) %></p>
      <p class="mt-1 text-sm text-slate-600"><%= payment_due_hint(@payment) %></p>
    </div>

    <dl class="mt-8 grid gap-5 rounded-2xl border border-slate-200 bg-white p-6 sm:grid-cols-2">
      <div>
        <dt class="text-sm font-medium text-slate-500">Loan</dt>
        <dd class="mt-2 text-lg font-semibold text-slate-950">
          <%= link_to loan.loan_number, loan_path(loan), class: "underline decoration-slate-300 underline-offset-4 transition hover:decoration-slate-500" %>
        </dd>
      </div>

      <div>
        <dt class="text-sm font-medium text-slate-500">Borrower</dt>
        <dd class="mt-2 text-lg font-semibold text-slate-950">
          <%= link_to borrower.full_name, borrower_path(borrower), class: "underline decoration-slate-300 underline-offset-4 transition hover:decoration-slate-500" %>
        </dd>
      </div>

      <% if loan.loan_application.present? %>
        <div>
          <dt class="text-sm font-medium text-slate-500">Linked application</dt>
          <dd class="mt-2 text-lg font-semibold text-slate-950">
            <%= link_to loan.loan_application.application_number, loan_application_path(loan.loan_application), class: "underline decoration-slate-300 underline-offset-4 transition hover:decoration-slate-500" %>
          </dd>
        </div>
      <% end %>

      <div>
        <dt class="text-sm font-medium text-slate-500">View all payments for this loan</dt>
        <dd class="mt-2">
          <%= link_to "All payments for #{loan.loan_number}", payments_path(q: loan.loan_number), class: "text-sm font-semibold text-slate-700 underline decoration-slate-300 underline-offset-4 transition hover:decoration-slate-500" %>
        </dd>
      </div>

      <div>
        <dt class="text-sm font-medium text-slate-500">Installment number</dt>
        <dd class="mt-2 text-lg font-semibold text-slate-950">#<%= @payment.installment_number %></dd>
      </div>

      <div>
        <dt class="text-sm font-medium text-slate-500">Due date</dt>
        <dd class="mt-2 text-lg font-semibold text-slate-950"><%= @payment.due_date.to_fs(:long) %></dd>
      </div>

      <div>
        <dt class="text-sm font-medium text-slate-500">Principal</dt>
        <dd class="mt-2 text-lg font-semibold text-slate-950"><%= humanized_money_with_symbol(@payment.principal_amount) %></dd>
      </div>

      <div>
        <dt class="text-sm font-medium text-slate-500">Interest</dt>
        <dd class="mt-2 text-lg font-semibold text-slate-950"><%= humanized_money_with_symbol(@payment.interest_amount) %></dd>
      </div>

      <div>
        <dt class="text-sm font-medium text-slate-500">Total</dt>
        <dd class="mt-2 text-lg font-semibold text-slate-950"><%= humanized_money_with_symbol(@payment.total_amount) %></dd>
      </div>

      <div>
        <dt class="text-sm font-medium text-slate-500">Late fee</dt>
        <dd class="mt-2 text-lg font-semibold text-slate-950">
          <%= @payment.late_fee_cents.to_i.positive? ? humanized_money_with_symbol(@payment.late_fee) : "—" %>
        </dd>
      </div>

      <div>
        <dt class="text-sm font-medium text-slate-500">Repayment frequency</dt>
        <dd class="mt-2 text-lg font-semibold text-slate-950"><%= loan.repayment_frequency_label %></dd>
      </div>

      <div>
        <dt class="text-sm font-medium text-slate-500">Current repayment state</dt>
        <dd class="mt-2 text-lg font-semibold text-slate-950">
          <%= @payment.status_label %>
          <span class="block text-sm font-medium text-slate-500"><%= payment_due_hint(@payment) %></span>
        </dd>
      </div>

      <div>
        <dt class="text-sm font-medium text-slate-500">Payment date</dt>
        <dd class="mt-2 text-lg font-semibold text-slate-950"><%= @payment.payment_date&.to_fs(:long) || (@payment.completed? ? "—" : "Not recorded yet") %></dd>
      </div>

      <div>
        <dt class="text-sm font-medium text-slate-500">Payment mode</dt>
        <dd class="mt-2 text-lg font-semibold text-slate-950"><%= @payment.payment_mode_label || (@payment.completed? ? "—" : "Not recorded yet") %></dd>
      </div>

      <div>
        <dt class="text-sm font-medium text-slate-500">Completed at</dt>
        <dd class="mt-2 text-lg font-semibold text-slate-950"><%= @payment.completed_at&.to_fs(:long) || "—" %></dd>
      </div>

      <div class="sm:col-span-2">
        <dt class="text-sm font-medium text-slate-500">Notes</dt>
        <dd class="mt-2 text-base leading-6 text-slate-800"><%= @payment.notes.presence || "Not provided yet" %></dd>
      </div>
    </dl>

  </section>
</section>
